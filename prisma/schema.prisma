generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Server {
  id               String   @id
  name             String
  slug             String   @unique
  icon             String?
  description      String?
  tags             String?
  inviteUrl        String?
  lastBumpAt       DateTime?
  bumpCount        Int      @default(0)
  botInstalled     Boolean  @default(false)
  moderationStatus String   @default("pending")
  moderationNote   String?
  ownerDiscordId   String?
  permissionLabel  String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}